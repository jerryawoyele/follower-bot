# Solana RPC URL (use a high-quality RPC for best performance)
RPC_URL=https://api.mainnet-beta.solana.com

# Helius API Key for transaction polling
HELIUS_API_KEY=your_helius_api_key_here

# Your bot's private key (base58 encoded) - 
PRIVATE_KEY=your_base58_private_key_here

# Jupiter API Key (get from https://jupiter.co)
JUPITER_API_KEY=your_jupiter_api_key_here

# The wallet address you want to follow/copy
LEADER_WALLET=target_wallet_address_here

# Amount of SOL to use per copied buy (in SOL)
BUY_AMOUNT_SOL=0.01

# Polling interval in milliseconds (default: 200ms = 5 req/sec)
POLLING_INTERVAL_MS=200

# Slippage tolerance in basis points (1000 = 10%)
SLIPPAGE_BPS=10000

# Priority fee in lamports
PRIORITY_FEE_LAMPORTS=300000

# Broadcast fee type: "maxCap" or "exactFee"
BROADCAST_FEE_TYPE=maxCap

# Jito tip in lamports (optional, for faster execution)
JITO_TIP_LAMPORTS=0
